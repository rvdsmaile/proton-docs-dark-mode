{
  "manifest_version": 3,
  "name": "Proton Docs Dark Mode (Local)",
  "version": "0.1.0",
  "description": "A local-only dark reading and editing mode for Proton Docs.",
  "permissions": ["storage"],
  "host_permissions": ["https://docs.proton.me/*"],
  "action": {
    "default_title": "Proton Docs Dark Mode",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.proton.me/*"],
      "js": ["content.js"],
      "css": ["dark-mode.css"],
      "run_at": "document_start"
    }
  ]
}
